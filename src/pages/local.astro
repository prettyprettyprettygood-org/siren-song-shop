import SiteFooter from '../components/SiteFooter.astro';
import ResourceCard from '../components/ResourceCard.astro';
import CategoryTabsNav from '../components/CategoryTabsNav.astro';

type LocalKindId = 'shops' | 'restaurants' | 'service';

type USStateCode = 'CA' | 'DC' | 'MD' | 'MN' | 'NC' | 'NY' | 'OR' | 'PA' | 'VA';

interface LocalKindTab {
  id: LocalKindId;
  label: string;
  description: string;
}

interface LocalEntry {
  name: string;
  url: string;
  description: string;
  kind: LocalKindId;
  state: USStateCode;
  city: string;
  zip: string;
}

