const states = Array.from(new Set(localEntries.map((entry) => entry.state))).sort();
---

<BaseLayout
  title="Local Gems | Siren Song"
  description="Browse local shops, services, and places to visit. Filter by state to focus on what is nearby."
>
  <SiteNav />
  <main id="main-content" class="container">
    <section class="page-hero" aria-labelledby="local-heading">
      <div class="hero-head">
        <div class="hero-title-group">
          <p class="kicker">Local Gems</p>
          <h1 id="local-heading">Good Spots Nearby</h1>
        </div>

        <section class="filter-bar" aria-label="Filter local gems">
          <p id="state-filter-label" class="filter-label">State</p>
          <div class="state-dropdown" data-state-dropdown>
            <button
              type="button"
              class="state-trigger"
              data-state-trigger
              aria-haspopup="menu"
              aria-expanded="false"
              aria-labelledby="state-filter-label state-filter-value"
            >
              <span id="state-filter-value" data-state-value>All states</span>
              <svg class="state-trigger-chevron" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
            <div class="state-options" data-state-options role="menu" aria-label="State filter" hidden>
              <button type="button" class="state-option state-option--active" data-state-option data-value="all" role="menuitemradio" aria-checked="true">
                All states
              </button>
              {states.map((stateCode) => (
                <button type="button" class="state-option" data-state-option data-value={stateCode} role="menuitemradio" aria-checked="false">
                  {stateCode}
                </button>
              ))}
            </div>
          </div>
        </section>
      </div>

      <p class="intro">
        Explore local picks by type, then filter by state. We are starting with North Carolina and
        expanding from there.
      </p>
    </section>

    <CategoryTabsNav
      categories={categories.map(({ id, label }) => ({ id, label }))}
      ariaLabel="Local categories"
      dropdownLabel="Select local category"
    />

    {categories.map(({ id, label, description }, index) => {
      const entries = byKind(id);
      return (
        <section
          id={`${id}-panel`}
          aria-labelledby={`${id}-tab`}
          role="tabpanel"
          class="category-section"
          data-reveal
          data-category-panel
          data-category={id}
          hidden={index !== 0}
        >
          <header class="category-header">
            <h2 class="section-heading">{label}</h2>
            <p class="category-description">{description}</p>
          </header>
          <ul class="local-grid">
            {entries.map((entry) => (
              <li data-local-card data-state={entry.state}>
                <ResourceCard
                  name={entry.name}
                  url={entry.url}
                  description={entry.description}
                  location={`${entry.city}, ${entry.state}`}
                />
              </li>
            ))}
          </ul>
          <p class="empty-state" data-empty-state hidden={entries.length > 0}>
            No entries yet for this category.
          </p>
        </section>
      );
    })}
  </main>
  <SiteFooter />
</BaseLayout>

<script>
  const w = window as Window & { __sirenLocalStateFilterBound?: boolean };

  const applyLocalStateFilter = () => {
    const selected =
      document.querySelector<HTMLButtonElement>('[data-state-option].state-option--active')
        ?.dataset.value ?? 'all';
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-category-panel]'));

    panels.forEach((panel) => {
      if (panel.hidden) return;
      const cards = Array.from(panel.querySelectorAll<HTMLElement>('[data-local-card]'));
      cards.forEach((card) => {
        const state = card.dataset.state;
        card.hidden = selected !== 'all' && state !== selected;
      });

      const emptyState = panel.querySelector<HTMLElement>('[data-empty-state]');
      const visibleCount = cards.filter((card) => !card.hidden).length;
      if (emptyState) {
        emptyState.hidden = visibleCount > 0;
      }
    });
  };

  const initializeStateFilter = () => {
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-category-panel]'));
    const stateDropdown = document.querySelector<HTMLElement>('[data-state-dropdown]');
    const stateTrigger = document.querySelector<HTMLButtonElement>('[data-state-trigger]');
    const stateValueLabel = document.querySelector<HTMLElement>('[data-state-value]');
    const stateOptionsPanel = document.querySelector<HTMLElement>('[data-state-options]');
    const stateOptions = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-state-option]'));
    if (panels.length === 0) return;

    const focusStateOption = (offset: number, from?: HTMLButtonElement) => {
      if (stateOptions.length === 0) return;
      const currentIndex = from ? stateOptions.indexOf(from) : 0;
      const safeIndex = currentIndex >= 0 ? currentIndex : 0;
      const nextIndex = (safeIndex + offset + stateOptions.length) % stateOptions.length;
      stateOptions[nextIndex]?.focus();
    };

    const closeStateOptions = () => {
      if (!stateTrigger || !stateOptionsPanel) return;
      stateOptionsPanel.hidden = true;
      stateTrigger.setAttribute('aria-expanded', 'false');
      if (stateDropdown) {
        delete stateDropdown.dataset.open;
      }
    };

    const openStateOptions = () => {
      if (!stateTrigger || !stateOptionsPanel) return;
      stateOptionsPanel.hidden = false;
      stateTrigger.setAttribute('aria-expanded', 'true');
      if (stateDropdown) {
        stateDropdown.dataset.open = 'true';
      }
    };

    const setSelectedState = (value: string, label: string) => {
      if (stateValueLabel) {
        stateValueLabel.textContent = label;
      }

      stateOptions.forEach((option) => {
        const isSelected = option.dataset.value === value;
        option.classList.toggle('state-option--active', isSelected);
        option.setAttribute('aria-checked', String(isSelected));
      });

      applyLocalStateFilter();
    };

    if (stateTrigger && stateOptionsPanel && stateTrigger.dataset.stateTriggerBound !== 'true') {
      stateTrigger.addEventListener('click', () => {
        if (stateOptionsPanel.hidden) {
          openStateOptions();
        } else {
          closeStateOptions();
        }
      });

      stateTrigger.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          openStateOptions();
          const active = stateOptions.find((opt) => opt.classList.contains('state-option--active'));
          (active ?? stateOptions[0])?.focus();
        }

        if (event.key === 'ArrowUp') {
          event.preventDefault();
          openStateOptions();
          const active = stateOptions.find((opt) => opt.classList.contains('state-option--active'));
          (active ?? stateOptions[stateOptions.length - 1])?.focus();
        }

        if (event.key === 'Escape') {
          event.preventDefault();
          closeStateOptions();
        }
      });

      stateTrigger.dataset.stateTriggerBound = 'true';
    }

    stateOptions.forEach((option) => {
      if (option.dataset.stateOptionBound === 'true') return;

      option.addEventListener('click', () => {
        const value = option.dataset.value;
        if (!value) return;
        setSelectedState(value, option.textContent?.trim() ?? value);
        closeStateOptions();
        stateTrigger?.focus();
      });

      option.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown') {
          event.preventDefault();
          focusStateOption(1, option);
        }

        if (event.key === 'ArrowUp') {
          event.preventDefault();
          focusStateOption(-1, option);
        }

        if (event.key === 'Home') {
          event.preventDefault();
          stateOptions[0]?.focus();
        }

        if (event.key === 'End') {
          event.preventDefault();
          stateOptions[stateOptions.length - 1]?.focus();
        }

        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          option.click();
        }

        if (event.key === 'Escape') {
          event.preventDefault();
          closeStateOptions();
          stateTrigger?.focus();
        }

        if (event.key === 'Tab') {
          closeStateOptions();
        }
      });

      option.dataset.stateOptionBound = 'true';
    });

    if (stateDropdown && stateDropdown.dataset.stateOutsideBound !== 'true') {
      document.addEventListener('click', (event) => {
        const target = event.target as Node;
        if (!stateDropdown.contains(target)) {
          closeStateOptions();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeStateOptions();
        }
      });

      stateDropdown.dataset.stateOutsideBound = 'true';
    }

    applyLocalStateFilter();
  };

  initializeStateFilter();

  if (!w.__sirenLocalStateFilterBound) {
    document.addEventListener('astro:page-load', initializeStateFilter);
    document.addEventListener('siren-category-change', () => {
      applyLocalStateFilter();
    });
    w.__sirenLocalStateFilterBound = true;
  }
</script>

<style>
  .page-hero {
    padding: var(--space-12) 0 var(--space-8);
  }

  .hero-head {
    display: grid;
    gap: var(--space-3);
    align-items: end;
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-pop);
    font-weight: 600;
    font-size: 0.8rem;
  }

  h1 {
    margin: var(--space-2) 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-text-strong);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .intro {
    margin: 0;
    margin-top: var(--space-5);
    color: var(--color-text-muted);
  }

  .filter-bar {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .filter-label {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-strong);
  }

  .state-dropdown {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    width: 100%;
    min-width: 11.5rem;
  }

  @media (min-width: 64rem) {
    .hero-head {
      grid-template-columns: minmax(0, 1fr) auto;
      column-gap: var(--space-6);
    }

    .filter-bar {
      justify-self: end;
      align-self: center;
    }

    h1 {
      margin-bottom: 0;
    }

    .intro {
      margin-top: var(--space-4);
    }
  }

  @media (min-width: 64rem) {
    .state-dropdown {
      width: auto;
    }
  }

  .state-trigger {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    background: color-mix(in oklab, var(--color-surface) 86%, transparent);
    color: var(--color-text-strong);
    padding: 0.5rem 0.85rem;
    font: inherit;
    font-weight: 600;
    line-height: 1.2;
    cursor: pointer;
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-accent-soft) 24%, transparent);
    transition: border-color 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
  }

  .state-trigger:hover {
    border-color: color-mix(in oklab, var(--color-accent-soft) 64%, var(--color-border-soft));
    background: color-mix(in oklab, var(--color-surface) 92%, transparent);
  }

  .state-trigger:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .state-trigger-chevron {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform 180ms ease;
  }

  .state-dropdown[data-open='true'] .state-trigger-chevron {
    transform: rotate(180deg);
  }

  .state-options {
    list-style: none;
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    right: 0;
    z-index: 10;
    margin: 0;
    padding: 0.35rem;
    border: 1px solid var(--color-menu-border);
    border-radius: var(--radius-md);
    background: var(--color-surface-card);
    box-shadow: var(--shadow-menu);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  :root[data-theme='dark'] .state-options {
    border-color: var(--color-border-soft);
    background: color-mix(in srgb, var(--color-bg) 94%, transparent);
    box-shadow: var(--shadow-menu-dark);
  }

  .state-option {
    width: 100%;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    padding: 0.45rem 0.6rem;
    background: transparent;
    color: var(--color-menu-option-text);
    text-align: left;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: color 180ms ease, background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  :root[data-theme='dark'] .state-option {
    color: var(--color-text-muted);
